  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "requests": {},
        "exec": [
          "// Enforce BaseURL is configured before any request runs.",
          "// Looks up the resolved value (env > collection > globals) and validates it.",
          "",
          "(function () {",
          "    const resolved = pm.variables.get('BaseURL'); // resolved variable based on Postman precedence",
          "    const hasValue = (typeof resolved === 'string') && resolved.trim().length > 0;",
          "",
          "    if (!hasValue || !resolved.trim().toLowerCase().startsWith('http')) {",
          "        const example = 'https://jsonplaceholder.typicode.com';",
          "        const msg = `Missing/invalid BaseURL.\\n\\n` +",
          "            `Set variable \\\"BaseURL\\\" in environment \\\"New Environment\\\" (UID: 30769584-51604f44-cc3a-4981-b3a8-37a26a4332dd) or in Globals.\\n` +",
          "            `Example: ${example}`;",
          "",
          "        // Fail fast: stop the collection run.",
          "        pm.execution.setNextRequest(null);",
          "",
          "        // Create a failing test with a clear message.",
          "        pm.test('BaseURL must be set (fail fast)', function () {",
          "            pm.expect.fail(msg);",
          "        });",
          "",
          "        return;",
          "    }",
          "",
          "    // Normalize (trim + remove trailing slashes) and store for optional later use.",
          "    const normalized = resolved.trim().replace(/\\/+$/, '');",
          "    pm.collectionVariables.set('baseUrlNormalized', normalized);",
          "})();",
          ""
        ]
      }
    },
