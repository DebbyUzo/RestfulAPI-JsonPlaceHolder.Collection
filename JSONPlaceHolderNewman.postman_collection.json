                  "    pm.expect(obj).to.have.property(\"userId\");",
                  "});",
                  "",
                  "pm.test(\"Patched fields are reflected in response\", function () {",
                  "    let reqBody;",
                  "    try {",
                  "        reqBody = pm.request.body && pm.request.body.raw ? JSON.parse(pm.request.body.raw) : null;",
                  "    } catch (e) { reqBody = null; }",
                  "",
                  "    if (reqBody && typeof reqBody === \"object\") {",
                  "        Object.keys(reqBody).forEach(function(k) {",
                  "            if (Object.prototype.hasOwnProperty.call(obj, k)) {",
                  "                const v = reqBody[k];",
                  "                if ([\"string\", \"number\", \"boolean\"].includes(typeof v) || v === null) {",
                  "                    pm.expect(obj[k]).to.eql(v);",
                  "                }",
                  "            }",
                  "        });",
                  "    }",
