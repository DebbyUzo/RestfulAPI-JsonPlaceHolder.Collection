              "listen": "test",
              "script": {
                "exec": [
                  "",
                  "// Status 200",
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// Response time < 2000ms",
                  "pm.test(\"Response time is less than 2000ms\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(3040);",
                  "});",
                  "",
                  "// Response is valid JSON",
                  "pm.test(\"Response is valid JSON\", function () {",
                  "    pm.response.to.be.json;",
                  "});",
                  "",
                  "const jsonData = pm.response.json();",
                  "",
                  "// Response has required fields",
                  "pm.test(\"Response has id, name, createdAt, data fields\", function () {",
                  "    pm.expect(jsonData).to.have.property('id');",
                  "    pm.expect(jsonData).to.have.property('name');",
                  "    pm.expect(jsonData).to.have.property('createdAt');",
                  "    pm.expect(jsonData).to.have.property('data');",
                  "});",
                  "",
                  "// id is a non-empty string",
                  "pm.test(\"id is a non-empty string\", function () {",
                  "    pm.expect(jsonData.id).to.be.a('string').and.to.have.length.above(0);",
                  "});",
                  "",
                  "// name is a non-empty string",
                  "pm.test(\"name is a non-empty string\", function () {",
                  "    pm.expect(jsonData.name).to.be.a('string').and.to.have.length.above(0);",
                  "});",
                  "",
                  "// data is an object with correct field types",
                  "pm.test(\"data is an object with correct field types\", function () {",
                  "    pm.expect(jsonData.data).to.be.an('object');",
                  "    if (jsonData.data.year !== undefined) {",
                  "        pm.expect(jsonData.data.year).to.be.a('number');",
                  "    }",
                  "    if (jsonData.data.price !== undefined) {",
                  "        pm.expect(jsonData.data.price).to.be.a('number');",
                  "    }",
                  "    if (jsonData.data['CPU model'] !== undefined) {",
                  "        pm.expect(jsonData.data['CPU model']).to.be.a('string');",
                  "    }",
                  "    if (jsonData.data['Hard disk size'] !== undefined) {",
                  "        pm.expect(jsonData.data['Hard disk size']).to.be.a('string');",
                  "    }",
                  "});",
                  "",
                  "// Save createdObjectId",
                  "pm.collectionVariables.set(\"createdObjectId\", jsonData.id);",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
