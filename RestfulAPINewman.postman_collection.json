        {
          "name": "List of All Objects",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "",
                  "// Status 200",
                  "let data = pm.response.json();",
                  "",
                  "// reuse it instead of redeclaring",
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has data\", function () {",
                  "    pm.expect(data).to.not.be.empty;",
                  "});",
                  "",
                  "",
                  "// Response time < 2000ms",
                  "pm.test(\"Response time is less than 2000ms\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(26070);",
                  "});",
                  "",
                  "// Response is valid JSON",
                  "pm.test(\"Response is valid JSON\", function () {",
                  "    pm.response.to.be.json;",
                  "});",
                  "",
                  "// Response is a non-empty array",
                  "pm.test(\"Response is a non-empty array\", function () {",
                  "    pm.expect(data).to.be.an('array').and.to.have.length.above(0);",
                  "});",
                  "",
                  "// Each item has id (string or number), optional name (string), optional data (object)",
                  "pm.test(\"Each item has id, optional name and optional data with correct types\", function () {",
                  "    data.forEach(function (item) {",
                  "        pm.expect(item).to.have.property('id');",
                  "        pm.expect(item.id).to.satisfy(function (id) {",
                  "            return typeof id === 'string' || typeof id === 'number';",
                  "        }, 'id should be string or number');",
                  "        if (item.name !== undefined) {",
                  "            pm.expect(item.name).to.be.a('string');",
                  "        }",
                  "        if (item.data !== undefined && item.data !== null) {",
                  "            pm.expect(item.data).to.be.an('object');",
                  "        }",
                  "    });",
                  "});",
                  "",
                  "// Save first item's id",
                  "pm.collectionVariables.set(\"lastObjectId\", String(data[0].id));",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
