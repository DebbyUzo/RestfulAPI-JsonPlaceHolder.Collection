  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "",
          "(function () {",
          "    const resolved = pm.variables.get('BaseUrl');",
          "    const hasValue = (typeof resolved === 'string') && resolved.trim().length > 0;",
          "",
          "    if (!hasValue || !resolved.trim().toLowerCase().startsWith('http')) {",
          "        const example = 'https://api.restful-api.dev';",
          "        const msg = `Missing/invalid BaseUrl.\\n\\nSet variable \"BaseUrl\" in the collection variables or active environment.\\nExample: ${example}`;",
          "",
          "        pm.execution.setNextRequest(null);",
          "",
          "        pm.test('BaseUrl must be set (fail fast)', function () {",
          "            pm.expect.fail(msg);",
          "        });",
          "",
          "        return;",
          "    }",
          "",
          "    const normalized = resolved.trim().replace(/\\/+$/, '');",
          "    pm.collectionVariables.set('BaseUrl', normalized);",
          "",
          "    console.log(`[${new Date().toISOString()}] Running request: \"${pm.info.requestName}\"`);",
          "})();",
          ""
        ]
      }
    }
